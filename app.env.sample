# SearXNG - Privacy-respecting meta search engine
# Copy to app.env and customize before starting

# Timezone
TZ=America/New_York

# Hostname / Domain
BASE_HOST_NAME=${HOSTNAME}
BASE_DOMAIN_NAME=example.com

# Application secret key (must be at least 32 characters)
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# Instance name shown in the UI
SEARXNG_INSTANCE_NAME=SearXNG

# Safe search level: 0=off, 1=moderate, 2=strict
SEARXNG_SAFE_SEARCH=2

# Autocomplete engine (duckduckgo, google, etc.)
SEARXNG_AUTOCOMPLETE=duckduckgo

# Enable request rate limiting
SEARXNG_LIMITER=true

# Enable image proxy
SEARXNG_IMAGE_PROXY=true

# Expose as public instance
SEARXNG_PUBLIC_INSTANCE=false

# uWSGI workers and threads
UWSGI_WORKERS=4
UWSGI_THREADS=4

# Valkey/Redis max memory
VALKEY_MAXMEMORY=256mb
